package com.sai.spring_layer.service;

import java.util.Scanner;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.stereotype.Service;
import com.sai.spring_layer.entity.ProductEntity;
import com.sai.spring_layer.repository.ProductRepository;

@Service
public class ProductService {
	@Autowired
	private ProductRepository productRepository;
	Scanner sc=new Scanner(System.in);

	public void addProduct() {
		ProductEntity p=new ProductEntity();
		p.setProductId(sc.nextInt());
		p.setProductName(sc.next());
		p.setProductPrice(sc.nextInt());

		productRepository.addProduct(p);
		System.out.println("product is added sucessfully");
	}

	public void findProductById() {
		System.out.println("enter the id:");
		ProductEntity p=productRepository.findProductById(sc.nextInt());
		if(p != null) {
			System.out.println("product id:"+p.getProductId());
			System.out.println("product name:"+p.getProductName());
			System.out.println("product price:"+p.getProductPrice());
		}
		else {
			System.out.println("product not found");
		}
	}
}
