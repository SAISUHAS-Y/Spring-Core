package com.sai.spring_layer.repository;

import javax.persistence.EntityManager;
import javax.persistence.EntityManagerFactory;
import javax.persistence.EntityTransaction;
import javax.persistence.Persistence;
import org.springframework.stereotype.Repository;
import com.sai.spring_layer.entity.ProductEntity;

@Repository
public class ProductRepository {
	EntityManagerFactory emf=Persistence.createEntityManagerFactory("mysql-config");

	public void  addProduct(ProductEntity p) {
		EntityManager em=emf.createEntityManager();
		EntityTransaction et=em.getTransaction();
		et.begin();
		
		em.persist(p);
		
		et.commit();
		em.close();
	}
	
	public ProductEntity findProductById(int productId) {
		EntityManager em=emf.createEntityManager();
		EntityTransaction et=em.getTransaction();
		et.begin();
		
		ProductEntity pe=em.find(ProductEntity.class, productId);
		
		et.commit();
		em.close();
		
		return pe;
	}
}
